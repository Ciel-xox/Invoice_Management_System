# --- 本番では Vercel に設定 ---

# Vercel Postgres (Neon) - Vercel が自動で設定する
POSTGRES_URL=

# Vercel Blob - Vercel Blob 連携で自動付与
BLOB_READ_WRITE_TOKEN=

# === Google Drive 連携（OAuth 2.0 方式）===
# 親フォルダ ID（このフォルダ配下に企業ごとのフォルダを自動作成する）
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Google Cloud Console → 認証情報 → OAuth 2.0 クライアント ID（Web アプリ）
# Authorized redirect URIs に <APP_URL>/api/auth/callback を登録すること
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 一度だけ <APP_URL>/api/auth/google にアクセスして認可フローを通すと取れる
GOOGLE_OAUTH_REFRESH_TOKEN=

# Slack 通知用 Incoming Webhook URL
SLACK_WEBHOOK_URL=

# アプリの公開 URL
NEXT_PUBLIC_APP_URL=http://localhost:3100
